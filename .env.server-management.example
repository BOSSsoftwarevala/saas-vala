# Server Management System - Environment Configuration

# Copy this to your .env.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI/Anthropic API Configuration
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...  # If using Claude

# Server Management Configuration
# These can also be modified in src/config/serverManagementConfig.ts

# Pricing
SERVER_MONTHLY_PRICE=49.00
SERVER_BILLING_CURRENCY=USD

# Monitoring
SERVER_METRICS_INTERVAL=30000  # milliseconds (30 seconds)
SERVER_METRICS_RETENTION_DAYS=90

# Thresholds (%)
SERVER_CPU_WARNING_THRESHOLD=75
SERVER_CPU_CRITICAL_THRESHOLD=90
SERVER_RAM_WARNING_THRESHOLD=80
SERVER_RAM_CRITICAL_THRESHOLD=95
SERVER_DISK_WARNING_THRESHOLD=85
SERVER_DISK_CRITICAL_THRESHOLD=95

# AI Analysis
SERVER_AI_ANALYSIS_INTERVAL=3600000  # milliseconds (1 hour)
SERVER_AI_MODEL=claude-3-5-sonnet-20241022

# Agent Settings
AGENT_HEARTBEAT_INTERVAL=30000  # milliseconds
AGENT_TIMEOUT=120000  # milliseconds (2 minutes)
AGENT_AUTO_RESTART=true

# Billing
BILLING_CYCLE_DAY=1  # Day of month to charge
BILLING_PAYMENT_TERMS_DAYS=7  # Days to pay after invoice

# SSH Configuration
SSH_DEFAULT_PORT=22
SSH_TIMEOUT_MS=30000
SSH_KEY_ENCRYPTION=aes-256-cbc

# SSL Configuration
SSL_CHECK_INTERVAL=86400000  # milliseconds (24 hours)
SSL_EXPIRY_WARNING_DAYS=30
AUTO_RENEW_SSL=true

# Notifications
ENABLE_EMAIL_ALERTS=true
ENABLE_SLACK_ALERTS=false
ALERT_ON_HIGH_LOAD=true
ALERT_ON_DISK_FULL=true
ALERT_ON_SSL_EXPIRY=true
ALERT_ON_AGENT_OFFLINE=true

# Logging
LOG_RETENTION_DAYS=180
LOG_LEVEL=info

# Features
ENABLE_REAL_TIME_METRICS=true
ENABLE_AI_ANALYSIS=true
ENABLE_AUTO_SCALING=false
ENABLE_MULTI_REGION_FAILOVER=false

# Rate Limiting
AGENT_RATE_LIMIT_PER_HOUR=1000
USER_RATE_LIMIT_PER_HOUR=5000

# Server Providers
SUPPORTED_PROVIDERS=aws,digitalocean,hostinger,linode

# AWS Configuration (if using AWS provider)
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1

# DigitalOcean Configuration (if using DigitalOcean provider)
DIGITALOCEAN_API_TOKEN=dop_v1_...

# Hostinger Configuration (if using Hostinger)
HOSTINGER_API_KEY=...
HOSTINGER_API_SECRET=...

# Slack Configuration (for alerts)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_BOT_TOKEN=xoxb-...

# Email Configuration (for alerts and invoices)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# Sentry Configuration (for error tracking)
SENTRY_DSN=https://...@sentry.io/...

# Payment Gateway (for billing)
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Data Encryption
ENCRYPTION_KEY=your-256-bit-hex-key
ENCRYPTION_ALGORITHM=aes-256-cbc

# Feature Flags
FEATURE_FLAG_AUTO_SCALING=false
FEATURE_FLAG_TERRAFORM_SUPPORT=false
FEATURE_FLAG_KUBERNETES_SUPPORT=false

# Security
REQUIRE_MFA_FOR_SSH=false
VERIFY_AGENT_SIGNATURE=true
RATE_LIMIT_ENABLED=true

# Performance
ENABLE_METRICS_CACHING=true
CACHE_TTL_SECONDS=60
AGGREGATE_METRICS=true
AGGREGATE_INTERVAL_MS=300000

# Debugging
DEBUG_MODE=false
VERBOSE_LOGGING=false
